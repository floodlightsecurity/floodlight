{
  "manifest_version": 3,
  "name": "Floodlight",
  "version": "0.1.0",
  "description": "Open-source shadow AI discovery. Metadata only — your prompts never leave your machine. Source: github.com/floodlightsecurity/floodlight",
  "author": "Floodlight Security",
  "homepage_url": "https://floodlightsecurity.co",

  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],

  "host_permissions": [
    "*://chatgpt.com/*",
    "*://*.chatgpt.com/*",
    "*://claude.ai/*",
    "*://*.claude.ai/*",
    "*://gemini.google.com/*",
    "*://aistudio.google.com/*",
    "*://copilot.microsoft.com/*",
    "*://copilot.cloud.microsoft/*",
    "*://perplexity.ai/*",
    "*://*.perplexity.ai/*",
    "*://pi.ai/*",
    "*://character.ai/*",
    "*://*.character.ai/*",
    "*://huggingface.co/chat/*",
    "*://chat.mistral.ai/*",
    "*://chat.deepseek.com/*",
    "*://chat.qwen.ai/*",
    "*://kimi.moonshot.cn/*",
    "*://groq.com/playground/*",
    "*://poe.com/*",
    "*://*.poe.com/*",
    "*://openai.com/*",
    "*://*.openai.com/*",
    "*://cursor.com/*",
    "*://*.cursor.com/*",
    "*://codeium.com/*",
    "*://*.codeium.com/*",
    "*://windsurf.com/*",
    "*://tabnine.com/*",
    "*://*.tabnine.com/*",
    "*://replit.com/*",
    "*://*.replit.com/*",
    "*://bolt.new/*",
    "*://*.bolt.new/*",
    "*://v0.dev/*",
    "*://*.v0.dev/*",
    "*://lovable.dev/*",
    "*://*.lovable.dev/*",
    "*://phind.com/*",
    "*://*.phind.com/*",
    "*://midjourney.com/*",
    "*://*.midjourney.com/*",
    "*://stability.ai/*",
    "*://firefly.adobe.com/*",
    "*://leonardo.ai/*",
    "*://*.leonardo.ai/*",
    "*://ideogram.ai/*",
    "*://*.ideogram.ai/*",
    "*://recraft.ai/*",
    "*://*.recraft.ai/*",
    "*://krea.ai/*",
    "*://*.krea.ai/*",
    "*://runwayml.com/*",
    "*://*.runwayml.com/*",
    "*://pika.art/*",
