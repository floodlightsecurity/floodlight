    "*://elevenlabs.io/*",
    "*://*.elevenlabs.io/*",
    "*://suno.com/*",
    "*://*.suno.com/*",
    "*://udio.com/*",
    "*://*.udio.com/*",
    "*://murf.ai/*",
    "*://*.murf.ai/*",
    "*://descript.com/*",
    "*://*.descript.com/*",
    "*://jasper.ai/*",
    "*://*.jasper.ai/*",
    "*://copy.ai/*",
