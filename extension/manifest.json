    "*://*.notion.so/*",
    "*://mem.ai/*",
    "*://*.mem.ai/*",
    "*://deepl.com/*",
    "*://*.deepl.com/*",
    "*://devin.ai/*",
    "*://*.devin.ai/*",
    "*://replika.com/*",
    "*://*.replika.com/*",
    "*://janitorai.com/*",
    "*://*.janitorai.com/*"
  ],

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

