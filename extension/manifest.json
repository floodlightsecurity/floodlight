        "*://*.read.ai/*",
        "*://notion.so/*",
        "*://*.notion.so/*",
        "*://mem.ai/*",
        "*://*.mem.ai/*",
        "*://deepl.com/*",
        "*://*.deepl.com/*",
        "*://devin.ai/*",
        "*://*.devin.ai/*",
